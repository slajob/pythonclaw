{
  "gateway": {
    "name": "pythonclaw",
    "host": "127.0.0.1",
    "port": 18789,
    "data_dir": "./.pythonclaw",
    "auth_token": null
  },
  "router": {
    "default_agent": "pi",
    "rules": [
      { "match": { "startswith": "@code" }, "agent": "coder" },
      { "match": { "startswith": "@pi" },   "agent": "pi" },
      { "match": { "startswith": "@gpt" },  "agent": "gpt" },
      { "match": { "startswith": "@ops" },  "agent": "ops" }
    ]
  },
  "agents": {
    "pi": {
      "provider": "echo",
      "system": "You are Pi, a helpful AI coding assistant.",
      "tools": ["time", "calc", "web_search"]
    },
    "coder": {
      "provider": "echo",
      "system": "You are Coder, a senior software engineer.",
      "tools": ["time", "calc"]
    },
    "gpt": {
      "provider": "openai",
      "system": "You are GPT, a helpful AI assistant.",
      "model": "gpt-4o",
      "tools": ["time", "calc", "web_search"]
    },
    "ops": {
      "provider": "echo",
      "system": "You can run shell commands and inspect files on the host.",
      "tools": ["time", "shell", "ls", "read_file"]
    }
  },
  "providers": {
    "echo": { "type": "echo" },
    "openai": {
      "type": "openai",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o",
      "allowed_models": ["gpt-5-mini", "gpt-4o", "gpt-5.2"]
    },
    "anthropic": {
      "type": "anthropic",
      "base_url": "https://api.anthropic.com/v1",
      "api_key_env": "ANTHROPIC_API_KEY",
      "model": "claude-sonnet-4-6"
    }
  },
  "channels": {
    "webchat": { "type": "webchat", "enabled": true },
    "cli":     { "type": "cli",     "enabled": false },
    "discord": { "type": "discord", "enabled": false, "token_env": "DISCORD_TOKEN" },
    "telegram":{ "type": "telegram","enabled": false, "token_env": "TELEGRAM_BOT_TOKEN" },
    "slack":   { "type": "slack",   "enabled": false, "token_env": "SLACK_BOT_TOKEN" }
  },
  "tools": {
    "shell": {
      "enabled": false,
      "allowed_cmds": [
        "ls", "cat", "echo", "pwd", "whoami", "date", "uname",
        "find", "head", "tail", "wc", "stat", "du", "df", "env",
        "hostname", "uptime", "ps", "free"
      ],
      "denied_cmds": [
        "rm", "rmdir", "mkfs", "dd", "shutdown", "reboot",
        "passwd", "sudo", "su", "chmod", "chown"
      ],
      "cwd": null,
      "timeout": 10,
      "max_output_bytes": 16384
    },
    "ls": {
      "enabled": false,
      "allowed_paths": ["/home", "/tmp"]
    },
    "read_file": {
      "enabled": false,
      "allowed_paths": ["/home", "/tmp"],
      "max_bytes": 65536
    }
  },
  "memory": {
    "engine": "sqlite",
    "path": "./.pythonclaw/memory.db",
    "max_messages_per_session": 200
  }
}
